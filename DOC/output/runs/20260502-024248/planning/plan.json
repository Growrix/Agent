    },
    {
      "name": "CLERK_WEBHOOK_SIGNING_SECRET",
      "scope": "server-only"
    },
    {
      "name": "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
      "scope": "client-safe"
    },
    {
      "name": "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
      "scope": "client-safe"
