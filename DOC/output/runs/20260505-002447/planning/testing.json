{
  "frameworks": {
    "unit": "Vitest",
    "integration": "Vitest + MSW",
    "e2e": "Playwright",
    "typecheck": "tsc --noEmit"
  },
  "coverage_thresholds": {
    "services_line_percent": 80,
    "utilities_line_percent": 90,
    "route_handlers": "integration-covered"
  },
  "critical_journeys": [
    "Emergency call path",
    "Quote request path",
    "Area trust path"
  ],
  "e2e_paths": [
    {
      "name": "hero_call_path",
      "route": "/",
      "assertions": [
        "Hero CTA visible",
        "tel link present",
        "No JS errors"
      ]
    },
    {
      "name": "quote_request_path",
      "route": "/quote",
      "assertions": [
        "Form validates",
        "Submission success state appears",
        "Lead endpoint returns ok"
      ]
    },
    {
      "name": "area_detail_to_quote_path",
      "route": "/areas/[slug]",
      "assertions": [
        "Area hero loads",
        "CTA routes to /quote",
        "No broken navigation"
      ]
    }
  ],
  "integration_tests": [
    "/api/leads returns validation errors on bad payload",
    "/api/leads returns success on valid Turnstile-verified payload",
    "/api/webhooks/sanity returns 200 on valid signature",
    "/api/webhooks/sanity returns 400 on invalid signature"
  ],
  "smoke_tests": [
    "GET / -> 200",
    "GET /quote -> 200",
    "GET /api/health -> 200"
  ],
  "ci_gates": [
    "eslint --max-warnings 0",
    "tsc --noEmit",
    "vitest run --coverage",
    "vitest run --config vitest.integration.config.ts",
    "playwright test"
  ]
}