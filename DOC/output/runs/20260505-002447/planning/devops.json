{
  "environments": [
    "local",
    "preview",
    "staging",
    "production"
  ],
  "platform": "vercel",
  "secrets_vault": "vercel",
  "ci_cd_file": ".github/workflows/ci.yml",
  "health_endpoint": "/api/health",
  "rollback_strategy": "vercel_instant_rollback",
  "rto_minutes": 60,
  "rpo_minutes": 15,
  "backup_retention_days": 30,
  "cost_ceiling_usd_per_month": {
    "staging": 40,
    "production": 180
  },
  "dns_steps": [
    "Manage DNS in Cloudflare.",
    "Point apex and www records to Vercel.",
    "Add Resend domain verification records once the sending domain is confirmed."
  ],
  "dashboards": [
    "Vercel project",
    "Sanity project",
    "Resend dashboard",
    "PostHog project",
    "Sentry project",
    "Axiom dataset",
    "Cloudflare Turnstile",
    "Cloudflare DNS",
    "Cookiebot"
  ],
  "monitoring": {
    "structured_logs": "axiom",
    "error_tracking": "sentry",
    "analytics": "posthog",
    "uptime_monitor": "betterstack-uptime"
  },
  "ci_pipeline": [
    "eslint --max-warnings 0",
    "tsc --noEmit",
    "vitest run --coverage",
    "vitest run --config vitest.integration.config.ts",
    "next build",
    "playwright test"
  ]
}