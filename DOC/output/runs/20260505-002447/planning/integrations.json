{
  "preset": "tier-basic-marketing-site",
  "feature_integrations": {
    "marketing_pages": {
      "primary": "sanity",
      "rule_file": "knowledge/integration-rules/cms/sanity.yaml",
      "required_components": {
        "frontend": [
          "sanity_provider_or_client_config",
          "portable_text_renderer",
          "image_component_with_sanity_image_url",
          "draft_mode_toggle_for_editors"
        ],
        "backend": [
          "sanity_client_singleton",
          "groq_query_helpers",
          "api_route_draft_mode_enable",
          "api_route_webhook_revalidation"
        ],
        "cms_studio": [
          "sanity_studio_colocated_or_hosted",
          "schema_definitions_per_content_type"
        ]
      },
      "env_vars": [
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "NEXT_PUBLIC_SANITY_DATASET",
        "SANITY_API_READ_TOKEN",
        "SANITY_WEBHOOK_SECRET"
      ],
      "webhooks": [
        {
          "endpoint": "/api/webhooks/sanity",
          "events": [
            "document.publish",
            "document.unpublish",
            "document.delete"
          ]
        }
      ],
      "setup_steps": [
        "create_sanity_project",
        "define_content_schemas",
        "configure_sanity_studio_route_in_nextjs",
        "install_packages",
        "create_sanity_client_singleton",
        "write_groq_queries_for_each_content_type",
        "configure_revalidation_webhook_in_sanity_dashboard",
        "implement_webhook_handler_with_secret_verification",
        "set_env_vars_in_vercel"
      ]
    },
    "emails": {
      "primary": "resend",
      "rule_file": "knowledge/integration-rules/email/transactional/resend.yaml",
      "required_components": {
        "backend": [
          "resend_client_singleton",
          "email_template_components",
          "email_service_helper"
        ]
      },
      "env_vars": [
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL"
      ],
      "webhooks": [],
      "setup_steps": [
        "create_resend_account",
        "verify_sending_domain_in_resend_dashboard",
        "install_resend_and_react_email_packages",
        "create_resend_client_singleton",
        "build_email_templates_as_react_components",
        "implement_email_service_helper",
        "add_env_vars"
      ]
    },
    "analytics": {
      "primary": "posthog",
      "rule_file": "knowledge/integration-rules/analytics/posthog.yaml",
      "required_components": {
        "frontend": [
          "posthog_provider_at_root",
          "page_view_tracking",
          "custom_event_tracking_helpers"
        ],
        "backend": [
          "server_side_event_capture_optional"
        ]
      },
      "env_vars": [
        "NEXT_PUBLIC_POSTHOG_KEY",
        "NEXT_PUBLIC_POSTHOG_HOST"
      ],
      "webhooks": [],
      "setup_steps": [
        "create_posthog_account",
        "install_posthog_js",
        "wrap_root_layout_with_posthog_provider",
        "configure_cookieless_mode_if_gdpr_required",
        "implement_pageview_tracking_on_route_change"
      ]
    }
  },
  "preset_integrations": {
    "hosting": "vercel",
    "dns": "cloudflare-dns",
    "email_tx": "resend",
    "analytics": "posthog",
    "error_tracking": "sentry",
    "logging": "axiom",
    "spam_guard": "cloudflare-turnstile",
    "cookie_consent": "cookiebot",
    "cms": "sanity"
  },
  "env_vars": [
    "NEXT_PUBLIC_SANITY_PROJECT_ID",
    "NEXT_PUBLIC_SANITY_DATASET",
    "SANITY_API_READ_TOKEN",
    "SANITY_WEBHOOK_SECRET",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "AXIOM_DATASET",
    "AXIOM_TOKEN",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "TURNSTILE_SECRET_KEY"
  ],
  "assumptions": [
    {
      "type": "integration_override",
      "role": "cms_optional",
      "preset_default": "sanity_optional_when_content_gt_3_pages",
      "selected": "sanity",
      "reason": "The site includes editable home, services, service detail, areas, area detail, reviews, about, FAQ, and legal content."
    }
  ]
}