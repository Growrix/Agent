    "success": "#2F7D4E",
    "warning": "#D79A22",
    "info": "#4E78A8",
    "focus-ring": "#78B8FF",
    "card": "#FFFFFF",
    "card-foreground": "#0E1E32",
    "popover": "#FFFFFF",
    "popover-foreground": "#0E1E32",
    "input": "#EEF3F8",
    "ring": "#78B8FF"
  },
  "color-dark": {
    "background": "#081522",
    "surface": "#0E2236",
    "inset": "#132A42",
    "overlay": "rgba(2, 9, 16, 0.76)",
    "border": "#20415D",
    "text": "#F4F8FC",
    "text-muted": "#BDD0E3",
    "primary": "#4EA1E6",
    "primary-hover": "#6CB3EE",
    "primary-foreground": "#08203A",
    "accent": "#E2A354",
    "accent-foreground": "#081522",
    "destructive": "#F26C5D",
    "destructive-foreground": "#081522",
    "success": "#62B07E",
    "warning": "#F0BF56",
    "info": "#8BB8E8",
    "focus-ring": "#A9D5FF",
