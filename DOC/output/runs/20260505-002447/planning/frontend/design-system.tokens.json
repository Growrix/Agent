    "card-foreground": "#F4F8FC",
    "popover": "#10263D",
    "popover-foreground": "#F4F8FC",
    "input": "#163049",
    "ring": "#A9D5FF"
  },
  "typography": {
    "fontFamily": {
      "display": "Space Grotesk",
      "body": "Plus Jakarta Sans",
      "mono": "JetBrains Mono"
    },
    "fontSize": {
      "display-1": "3.5rem",
      "display-2": "3rem",
      "h1": "2rem",
      "h2": "1.75rem",
      "h3": "1.5rem",
      "h4": "1.25rem",
      "h5": "1.125rem",
      "h6": "1rem",
      "lead": "1.125rem",
      "body-lg": "1.125rem",
      "body": "1rem",
      "body-sm": "0.875rem",
      "label": "0.875rem",
      "caption": "0.75rem",
      "overline": "0.75rem",
      "mono": "0.875rem"
    },
    "lineHeight": {
      "display-1": "1.05",
      "display-2": "1.08",
      "h1": "1.15",
      "h2": "1.2",
      "h3": "1.25",
      "h4": "1.3",
      "h5": "1.35",
      "h6": "1.4",
      "lead": "1.5",
      "body-lg": "1.65",
      "body": "1.65",
      "body-sm": "1.55",
      "label": "1.4",
      "caption": "1.4",
      "overline": "1.4",
      "mono": "1.5"
    },
    "letterSpacing": {
      "display": "-0.03em",
      "body": "0",
      "overline": "0.08em"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "display": 700
    }
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "6": 24,
    "8": 32,
    "12": 48,
    "16": 64,
    "24": 96,
    "32": 128
  },
  "sectionY": {
    "mobile": "2.5rem",
    "tablet": "3.5rem",
    "desktop": "5rem"
  },
  "radius": {
    "none": 0,
    "xs": 4,
    "sm": 6,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "2xl": 24,
    "3xl": 32,
    "full": 9999,
    "button": 12,
    "input": 12,
    "card": 16,
    "panel": 32
  },
  "shadow": {
    "1": "0 12px 30px rgba(13, 33, 56, 0.08)",
    "2": "0 18px 40px rgba(11, 34, 60, 0.14)",
    "3": "0 28px 60px rgba(7, 24, 43, 0.22)",
    "focus": "0 0 0 4px rgba(120, 184, 255, 0.35)"
  },
  "motion": {
    "duration": {
      "instant": "0ms",
      "fast": "160ms",
      "base": "220ms",
      "slow": "260ms",
      "cinematic": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.22, 1, 0.36, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "decel": "cubic-bezier(0, 0, 0.2, 1)",
      "accel": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "breakpoints": {
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1440
  },
  "container": {
    "sm": 640,
    "md": 768,
    "lg": 960,
    "xl": 1200,
    "2xl": 1440
  },
  "zIndex": {
    "base": 0,
    "content": 10,
    "sticky": 20,
    "dropdown": 30,
    "overlay": 40,
    "modal": 50,
    "toast": 60,
    "tooltip": 70,
    "debug": 90
  },
  "icon": {
    "size": {
      "xs": 16,
      "sm": 20,
      "md": 24,
      "lg": 32
    },
    "stroke": {
      "thin": 1.5,
      "base": 1.75,
      "bold": 2
    }
  }
}