{
  "meta": {
    "version": 1,
    "visual_archetype": "local-business-trust",
    "theme_mode": ["light", "dark"]
  },
  "color": {
    "light": {
      "brand": {
        "primary": "#0B4A3D",
        "primaryHover": "#0A4035",
        "accent": "#D97706",
        "accentHover": "#B45309"
      },
      "text": {
        "strong": "#0F172A",
        "default": "#1F2937",
        "muted": "#4B5563",
        "inverse": "#F9FAFB"
      },
      "surface": {
        "canvas": "#F8FAFC",
        "base": "#FFFFFF",
        "raised": "#F1F5F9",
        "overlay": "#0F172ACC"
      },
      "border": {
        "subtle": "#E2E8F0",
        "strong": "#94A3B8"
      },
      "state": {
        "success": "#15803D",
        "warning": "#B45309",
        "danger": "#B91C1C",
        "info": "#1D4ED8",
        "focusRing": "#0EA5E9"
      }
    },
    "dark": {
      "brand": {
        "primary": "#34D399",
        "primaryHover": "#10B981",
        "accent": "#F59E0B",
        "accentHover": "#D97706"
      },
      "text": {
        "strong": "#F8FAFC",
        "default": "#E2E8F0",
        "muted": "#94A3B8",
        "inverse": "#0F172A"
      },
      "surface": {
        "canvas": "#020617",
        "base": "#0B1220",
        "raised": "#111827",
        "overlay": "#020617E6"
      },
      "border": {
        "subtle": "#1F2937",
        "strong": "#334155"
      },
      "state": {
        "success": "#22C55E",
        "warning": "#F59E0B",
        "danger": "#EF4444",
        "info": "#60A5FA",
        "focusRing": "#38BDF8"
      }
    }
  },
  "typography": {
    "family": {
      "display": "var(--font-display)",
      "body": "var(--font-body)",
      "mono": "var(--font-mono)"
    },
    "scale": {
      "displayHero": "clamp(2.2rem, 6vw, 4.6rem)",
      "displaySection": "clamp(1.8rem, 4vw, 3rem)",
      "title": "clamp(1.3rem, 2.5vw, 2rem)",
      "body": "clamp(1rem, 1.4vw, 1.15rem)",
      "caption": "clamp(0.82rem, 1vw, 0.94rem)"
    }
  },
  "space": {
    "section": {"xxl": "var(--space-section-xxl)", "xl": "var(--space-section-xl)", "lg": "var(--space-section-lg)", "md": "var(--space-section-md)"},
    "stack": {"lg": "var(--space-stack-lg)", "md": "var(--space-stack-md)", "sm": "var(--space-stack-sm)"},
    "inline": {"lg": "var(--space-inline-lg)", "md": "var(--space-inline-md)", "sm": "var(--space-inline-sm)"}
  },
  "radius": {"sm": "var(--radius-sm)", "md": "var(--radius-md)", "lg": "var(--radius-lg)", "pill": "var(--radius-pill)"},
  "shadow": {"sm": "var(--shadow-sm)", "md": "var(--shadow-md)", "lg": "var(--shadow-lg)", "focus": "var(--shadow-focus)"},
  "motion": {
    "duration": {"fast": "var(--motion-duration-fast)", "base": "var(--motion-duration-base)", "slow": "var(--motion-duration-slow)"},
    "easing": {"standard": "var(--motion-ease-standard)", "enter": "var(--motion-ease-enter)", "exit": "var(--motion-ease-exit)"}
  },
  "breakpoint": {"mobile": "var(--bp-mobile)", "tablet": "var(--bp-tablet)", "desktop": "var(--bp-desktop)", "wide": "var(--bp-wide)"},
  "zIndex": {"base": "var(--z-base)", "sticky": "var(--z-sticky)", "overlay": "var(--z-overlay)", "modal": "var(--z-modal)", "toast": "var(--z-toast)"}
}
