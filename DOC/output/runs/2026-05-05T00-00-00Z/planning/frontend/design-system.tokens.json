      "label": "14px",
      "caption": "12px",
      "overline": "12px",
      "mono": "14px"
    },
    "lineHeight": {
      "display-1": "1.15",
      "display-2": "1.15",
      "h1": "1.2",
      "h2": "1.3",
      "h3": "1.3",
      "h4": "1.35",
      "h5": "1.35",
      "h6": "1.35",
      "lead": "1.6",
      "body-lg": "1.65",
      "body": "1.65",
      "body-sm": "1.65",
      "label": "1.4",
      "caption": "1.4",
      "overline": "1.4",
      "mono": "1.5"
    },
    "letterSpacing": {
      "display": "-0.01em",
      "body": "0",
      "overline": "0.06em"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "display": 800
    }
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "6": 24,
    "8": 32,
    "12": 48,
    "16": 64,
    "24": 96,
    "32": 128
  },
  "sectionY": {
    "mobile": "40px",
    "tablet": "56px",
    "desktop": "80px"
  },
  "radius": {
    "none": "0px",
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "3xl": "32px",
    "full": "9999px",
    "button": "12px",
    "input": "12px",
    "card": "12px",
    "panel": "16px"
  },
  "shadow": {
    "1": "0 1px 2px rgba(15, 23, 42, 0.06)",
    "2": "0 8px 20px rgba(15, 23, 42, 0.10)",
    "3": "0 20px 60px rgba(15, 23, 42, 0.18)",
    "focus": "0 0 0 3px rgba(15, 118, 110, 0.28)"
  },
  "motion": {
    "duration": {
      "instant": "0ms",
      "fast": "150ms",
      "base": "200ms",
      "slow": "260ms",
      "cinematic": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "spring": "cubic-bezier(0.16, 1, 0.3, 1)",
      "decel": "cubic-bezier(0, 0, 0.2, 1)",
      "accel": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "breakpoints": {
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1440
  },
  "container": {
    "sm": 640,
    "md": 768,
    "lg": 960,
    "xl": 1200,
    "2xl": 1440
  },
  "zIndex": {
    "base": 0,
    "content": 10,
    "sticky": 20,
    "dropdown": 30,
    "overlay": 40,
    "modal": 50,
    "toast": 60,
    "tooltip": 70,
    "debug": 90
  },
  "icon": {
    "size": {
      "xs": 16,
      "sm": 20,
      "md": 24,
      "lg": 32
    },
    "stroke": {
      "thin": 1.5,
      "base": 1.75,
      "bold": 2
    }
  }
