      "duration": "durationSlowest",
      "ease": "easeInOut",
      "staggerMs": null,
      "transform": "drift-x(-2%→2%)",
      "repeat": 9999,
      "yoyo": true,
      "reducedMotionFallback": "no-motion",
      "className": "motion-mesh-drift"
    },
