{
  "name": "blueprint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typegen": "next typegen",
    "typecheck": "npm run typegen && tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "ds:audit": "node scripts/ds-audit.mjs",
    "ds:a11y": "jest --runInBand src/ds/components/__tests__/keyboard.a11y.test.tsx src/ds/components/__tests__/keyboard-extended.a11y.test.tsx src/ds/runtime/app/mobile/__tests__/Sheet.test.tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build && npm run ds:audit && npm run ds:a11y"
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5"
  }
}
