# Public environment variables (client-visible)
# Copy to .env.local and fill in values.

# Backend API base URL.
# If not set, the API client returns mock data for local development.
NEXT_PUBLIC_API_BASE_URL=

# Google Analytics measurement ID (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# App URL (used for OG meta and sitemap)
NEXT_PUBLIC_APP_URL=https://solarpro.example.com
