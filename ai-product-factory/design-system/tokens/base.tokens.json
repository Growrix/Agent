{
  "theme": {
    "light": {
      "color": {
        "primary": "#0f172a",
        "secondary": "#1d4ed8",
        "accent": "#f59e0b",
        "surface": "#ffffff",
        "muted": "#e2e8f0",
        "success": "#059669",
        "warning": "#d97706",
        "danger": "#dc2626"
      }
    },
    "dark": {
      "color": {
        "primary": "#e2e8f0",
        "secondary": "#60a5fa",
        "accent": "#fbbf24",
        "surface": "#0f172a",
        "muted": "#1e293b",
        "success": "#34d399",
        "warning": "#f59e0b",
        "danger": "#f87171"
      }
    }
  },
  "typography": {
    "fontFamilies": {
      "display": "Sora",
      "body": "Manrope"
    },
    "scale": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.5rem",
      "2xl": "2rem",
      "3xl": "3rem"
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "4rem"
  },
  "radii": {
    "sm": "0.375rem",
    "md": "0.75rem",
    "lg": "1.25rem",
    "pill": "9999px"
  },
  "shadows": {
    "sm": "0 4px 12px rgba(15, 23, 42, 0.08)",
    "md": "0 12px 32px rgba(15, 23, 42, 0.14)",
    "lg": "0 24px 80px rgba(15, 23, 42, 0.18)"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "220ms",
