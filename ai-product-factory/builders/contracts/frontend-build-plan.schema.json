{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-product-factory.local/builders/contracts/frontend-build-plan.schema.json",
  "title": "FrontendBuildPlan",
  "type": "object",
  "required": ["projectSlug", "appRoot", "stack", "routes", "components", "scripts", "releaseGate"],
  "properties": {
    "projectSlug": { "type": "string" },
    "appRoot": { "type": "string" },
    "stack": {
      "type": "object",
      "required": ["framework", "language", "styling"],
      "properties": {
        "framework": { "type": "string" },
        "language": { "type": "string" },
        "styling": { "type": "string" }
      },
      "additionalProperties": true
    },
    "routes": { "type": "array", "items": { "type": "string" } },
    "components": { "type": "array", "items": { "type": "string" } },
    "scripts": { "type": "object", "additionalProperties": { "type": "string" } },
    "releaseGate": {
      "type": "object",
      "required": ["smokeJourneys", "requiredChecks"],
      "properties": {
        "smokeJourneys": { "type": "array", "items": { "type": "string" } },
        "requiredChecks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}